{
  "pluginName": "鹅的书签",
  "description": "参考 noice.so 风格的 uTools 书签插件，支持二级分类、搜索、图标缓存与无效检测",
  "version": "0.1.0",
  "author": "eachann",
  "homepage": "",
  "preload": "preload/preload.cjs",
  "main": "dist/index.html",
  "pluginSetting": {
    "height": 560
  },
  "logo": "logo.png",
  "features": [
    {
      "code": "bookmarks",
      "explain": "打开鹅的书签",
      "mainHide": false,
      "cmds": ["书签", "bookmark", "bookmarks"]
    },
    {
      "code": "save_link",
      "explain": "保存链接到书签",
      "mainHide": false,
      "cmds": [
        {
          "type": "regex",
          "label": "保存链接到书签",
          "match": "/^https?:\\/\\/.*$/i"
        }
      ],
      "platform": ["win32", "darwin", "linux"]
    },
    {
      "code": "quick_save",
      "explain": "快速保存当前页面到书签",
      "mainHide": false,
      "cmds": [
        "快速保存",
        "快速收藏",
        "quick save",
        {
          "type": "regex",
          "label": "快速保存到书签",
          "match": "/^https?:\\/\\/.*$/i"
        }
      ],
      "platform": ["win32", "darwin", "linux"]
    },
    {
      "code": "quick_save_dialog",
      "explain": "打开快速保存弹窗",
      "mainHide": false,
      "cmds": [
        "保存弹窗",
        "快速保存弹窗",
        "save dialog"
      ],
      "platform": ["win32", "darwin", "linux"]
    }
  ]
}
